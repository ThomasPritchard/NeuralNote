{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vitest/globals", "@testing-library/jest-dom/vitest"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  // Real-browser specs are type-checked by their own program (tsconfig.browser.json).
  // @vitest/browser ships a stricter `toHaveStyle` matcher augmentation; importing it
  // here would merge that signature program-wide and break jsdom tests' custom-property
  // style assertions. Keep its types out of this (jsdom) program.
  // NB: tsconfig globs do NOT support brace expansion — list each extension.
  "exclude": ["src/**/*.browser.test.ts", "src/**/*.browser.test.tsx"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
