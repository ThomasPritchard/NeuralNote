{
  "name": "desktop",
  "private": true,
  "version": "0.2.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "lint": "oxlint . --deny-warnings --report-unused-disable-directives",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:unit": "vitest run --exclude \"src/e2e/**\" && npm run test:updater-harness",
    "test:updater-harness": "node --test scripts/local-updater-harness.node-test.mjs",
    "test:run": "vitest run",
    "test:e2e": "vitest run src/e2e",
    "coverage": "vitest run --coverage",
    "audit:all": "npm audit --audit-level=high && npm --prefix e2e-native audit --audit-level=high",
    "gen:bindings": "cargo test --manifest-path ../../Cargo.toml --workspace export",
    "check:bindings": "npm run gen:bindings && git -C ../.. add --intent-to-add -- app/desktop/src/lib/bindings && git -C ../.. diff --exit-code -- app/desktop/src/lib/bindings",
    "updater:local": "node scripts/local-updater-harness.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-markdown": "6.5.1",
    "@codemirror/language": "6.12.4",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-virtual": "^3.14.5",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.0",
    "three-spritetext": "^1.10.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.2",
    "typescript": "7.0.2",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  }
}
